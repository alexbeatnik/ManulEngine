# ==============================================================================
# 😼 ManulEngine — Example .env
# ==============================================================================
# Copy this file to `.env` (same folder) to override defaults.
# If `.env` does not exist, ManulEngine uses built-in defaults.

# Ollama model name
MANUL_MODEL=qwen2.5:0.5b

# Browser visibility mode
# False = visible browser window (recommended for debugging)
# True  = headless
MANUL_HEADLESS=False

# ==============================================================================
# 🎛️ AI Controls
# ==============================================================================
# By default, process environment variables win over values in this file (safer
# for CI/prod). For local prompt tuning you can make repo `.env` override any
# already-set environment variables:
MANUL_DOTENV_OVERRIDE=False

# Confidence threshold for LLM fallback.
# - If best heuristic score >= threshold → Manul trusts heuristics.
# - If best heuristic score < threshold  → Manul asks the LLM.
# Special case: <= 0 disables LLM fallback completely.
#
# If you leave it unset, the engine auto-derives it from model size.
#MANUL_AI_THRESHOLD=500

# When True, ALL element resolution decisions go through the LLM element picker
# (heuristic short-circuits are bypassed).
MANUL_AI_ALWAYS=False

# How the LLM should treat heuristic scores when selecting an element:
# - prior  (default): score is a hint; LLM may override with a clear reason.
# - strict          : enforce best-score determinism (useful for synthetic/id-strict tests).
MANUL_AI_POLICY=prior

# ============================================================================== 
# 💾 Persistent Controls Cache
# ==============================================================================
# Save resolved controls per site in a disk cache (repo-root cache/ by default).
MANUL_CONTROLS_CACHE_ENABLED=True

# Optional custom location for the persistent cache directory.
# Relative paths are resolved from project root.
#MANUL_CONTROLS_CACHE_DIR=cache

# ============================================================================== 
# 🧾 Logging
# ==============================================================================
# Collapse whitespace in element names/thoughts and (optionally) truncate.
# 0 = no truncation.
MANUL_LOG_NAME_MAXLEN=0
MANUL_LOG_THOUGHT_MAXLEN=0

# ==============================================================================
# ⏱️ Timeouts (ms)
# ==============================================================================
MANUL_TIMEOUT=5000
MANUL_NAV_TIMEOUT=30000
