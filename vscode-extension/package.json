{
  "name": "manul-engine",
  "displayName": "ManulEngine",
  "description": "Hunt file language support, test runner and configuration UI for ManulEngine browser automation",
  "version": "0.0.84",
  "publisher": "manul-engine",
  "icon": "images/icon128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexbeatnik/ManulEngine"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "hunt",
    "playwright",
    "browser-automation",
    "e2e",
    "manul"
  ],
  "activationEvents": [
    "workspaceContains:**/*.hunt"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "breakpoints": [
      { "language": "hunt" }
    ],
    "languages": [
      {
        "id": "hunt",
        "aliases": [
          "Hunt",
          "ManulEngine Hunt"
        ],
        "extensions": [
          ".hunt"
        ],
        "icon": {
          "light": "images/icon16.png",
          "dark": "images/icon16.png"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hunt",
        "scopeName": "source.hunt",
        "path": "./syntaxes/hunt.tmLanguage.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "manul-engine",
          "title": "ManulEngine",
          "icon": "images/icon-activity.svg"
        }
      ]
    },
    "views": {
      "manul-engine": [
        {
          "type": "webview",
          "id": "manul.stepBuilder",
          "name": "Step Builder"
        },
        {
          "type": "webview",
          "id": "manul.configView",
          "name": "Configuration"
        },
        {
          "id": "manul.cacheView",
          "name": "Cache",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "manul.runHuntFile",
        "title": "ManulEngine: Run Hunt File",
        "icon": "$(play)"
      },
      {
        "command": "manul.debugHuntFile",
        "title": "ManulEngine: Debug Hunt File",
        "icon": "$(debug-alt)"
      },
      {
        "command": "manul.runHuntFileInTerminal",
        "title": "ManulEngine: Run Hunt File in Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "manul.newHuntFile",
        "title": "ManulEngine: New Hunt File",
        "icon": "$(new-file)"
      },
      {
        "command": "manul.insertSetup",
        "title": "ManulEngine: Insert [SETUP] Block"
      },
      {
        "command": "manul.insertTeardown",
        "title": "ManulEngine: Insert [TEARDOWN] Block"
      },
      {
        "command": "manul.generateDemoTest",
        "title": "ManulEngine: Generate Demo Test"
      },
      {
        "command": "manul.insertInlinePythonCall",
        "title": "ManulEngine: Insert Inline CALL PYTHON Step"
      },
      {
        "command": "manul.generateConfig",
        "title": "ManulEngine: Generate Default Config"
      },
      {
        "command": "manul.addDefaultPrompts",
        "title": "ManulEngine: Add Default Prompts"
      },
      {
        "command": "manul.clearAllCache",
        "title": "ManulEngine: Clear All Cache",
        "icon": "$(trash)"
      },
      {
        "command": "manul.clearSiteCache",
        "title": "Clear Cache for This Site",
        "icon": "$(trash)"
      },
      {
        "command": "manul.refreshCache",
        "title": "ManulEngine: Refresh Cache View",
        "icon": "$(refresh)"
      },
      {
        "command": "manul.debugHighlight",
        "title": "ManulEngine: Highlight Target Element",
        "icon": "$(eye)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "manul.runHuntFile",
          "when": "resourceExtname == .hunt",
          "group": "navigation@1"
        },
        {
          "command": "manul.debugHuntFile",
          "when": "resourceExtname == .hunt",
          "group": "navigation@2"
        },
        {
          "command": "manul.debugHighlight",
          "when": "resourceExtname == .hunt && manulDebugSessionActive",
          "group": "navigation@3"
        }
      ],
      "explorer/context": [
        {
          "command": "manul.runHuntFile",
          "when": "resourceExtname == .hunt",
          "group": "navigation@1"
        },
        {
          "command": "manul.debugHuntFile",
          "when": "resourceExtname == .hunt",
          "group": "navigation@2"
        },
        {
          "command": "manul.runHuntFileInTerminal",
          "when": "resourceExtname == .hunt",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "manul.clearSiteCache",
          "when": "view == manul.cacheView && viewItem == cacheEntry",
          "group": "inline"
        }
      ],
      "view/title": [
        {
          "command": "manul.clearAllCache",
          "when": "view == manul.cacheView",
          "group": "navigation@1"
        },
        {
          "command": "manul.refreshCache",
          "when": "view == manul.cacheView",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "ManulEngine",
      "properties": {
        "manulEngine.manulPath": {
          "type": "string",
          "default": "",
          "description": "Path to the manul CLI executable to use for running hunt files. Leave empty to auto-detect (.venv, venv, env, .env, then PATH)."
        },
        "manulEngine.configFile": {
          "type": "string",
          "default": "manul_engine_configuration.json",
          "description": "Name of the ManulEngine config file in the workspace root."
        },
        "manulEngine.workers": {
          "type": "number",
          "default": null,
          "description": "Maximum number of hunt files to run concurrently in Test Explorer. Overrides the `workers` key from manul_engine_configuration.json. Leave empty to read from the config file (default: 1)."
        },
        "manulEngine.testsHome": {
          "type": "string",
          "default": "tests",
          "description": "Directory where new hunt files are created by the Step Builder. Relative to workspace root or absolute path. Overrides the `tests_home` key in manul_engine_configuration.json."
        },
        "manulEngine.autoAnnotate": {
          "type": "boolean",
          "default": false,
          "description": "Automatically annotate hunt output with page names when the browser navigates to a page matched by `page_registry` in manul_engine_configuration.json. Sets the MANUL_AUTO_ANNOTATE environment variable when running hunts."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.x"
  },
  "dependencies": {
  }
}
